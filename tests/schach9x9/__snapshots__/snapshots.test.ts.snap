            <button id="opportunities-btn" class="action-icon-btn" title="Chancen anzeigen (O)">
              <svg viewBox="0 0 24 24" width="24" height="24" stroke="#f59e0b" stroke-width="2" fill="none">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
              </svg>
            </button>
            <button id="toggle-analysis-btn" class="action-icon-btn" title="Engine Analyse (A)">
              <svg viewBox="0 0 24 24" width="24" height="24" stroke="var(--accent-primary)" stroke-width="2" fill="none">
                <path d="M12 20v-8m-4 8v-4m8 4v-6m-12 6h16"></path>
              </svg>
            </button>
            <button id="toggle-opening-book-btn" class="action-icon-btn" title="Eröffnungsbuch (O)">
              <svg viewBox="0 0 24 24" width="24" height="24" stroke="#9f5fef" stroke-width="2" fill="none">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
