              <option value="pixel">Pixel</option>
              <option value="infernale">Infernale</option>
              <option value="wood">Holz</option>
              <option value="neon">Neon</option>
              <option value="minimalist">Minimalistisch</option>
              <option value="frost">Frost</option>
            </select>
            <button id="info-toggle-btn" class="action-icon-btn" title="Info / Log">
              <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="16" x2="12" y2="12"></line>
                <line x1="12" y1="8" x2="12.01" y2="8"></line>
              </svg>
            </button>
            <button id="fullscreen-btn" class="action-icon-btn" title="Vollbild (F)">
              <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
                <path d="M8 3H5a2 2 0 0 0-2 2v3"></path>
                <path d="M21 8V5a2 2 0 0 0-2-2h-3"></path>
                <path d="M3 16v3a2 2 0 0 0 2 2h3"></path>
                <path d="M16 21h3a2 2 0 0 0 2-2v-3"></path>
              </svg>
            </button>
          </div>
        </div>

        <!-- PANEL LAYER: Contextual side/top panels -->
        <div id="panel-layer">
          <!-- Analysis Panel (Deep Analysis) -->
          <div id="analysis-panel" class="analysis-panel hidden">
            <div class="analysis-header">
              <h3>Deep Analysis</h3>
              <button id="close-analysis-btn" class="close-icon-btn">×</button>
            </div>
            <div class="analysis-body">
              <div class="eval-section">
                <div class="eval-bar-container">
                  <div id="eval-bar" class="eval-bar"></div>
                </div>
                <div id="eval-score" class="eval-score">0.00</div>
              </div>
              <div class="top-moves-section">
                <h4>Top Züge</h4>
                <div id="top-moves-content" class="top-moves-list">
                  <!-- Top moves injected by JS -->
                </div>
              </div>
              <div class="analysis-controls">
                <div class="analysis-info" id="analysis-engine-info">Tiefe: - | Knoten: -</div>
                <button id="continuous-analysis-btn" class="btn-secondary small-btn">
                  🔄 Kontinuierlich
                </button>
              </div>
             
              <!-- Live Search Progress -->
              <div class="live-search-progress" style="margin-top: 1rem; padding: 0.75rem; background: rgba(0,0,0,0.2); border-radius: 8px; font-size: 0.85rem;">
                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.5rem; margin-bottom: 0.5rem;">
                  <div><strong>Tiefe:</strong> <span id="live-depth">-</span></div>
                  <div><strong>Knoten:</strong> <span id="live-nodes">-</span></div>
                  <div><strong>Bewertung:</strong> <span id="live-score">-</span></div>
                  <div><strong>Zeit:</strong> <span id="live-time">-</span></div>
                </div>
                <div style="margin-top: 0.5rem;">
                  <strong>Hauptvariante:</strong> <span id="live-pv" style="color: var(--accent-primary); font-family: monospace;">-</span>
                </div>
              </div>
             
            </div>
          </div>

          <!-- Opening Book Panel -->
          <div id="opening-book-panel" class="opening-book-panel hidden">
            <div class="opening-book-header">
              <h3>Eröffnungsbuch</h3>
              <button id="close-opening-book-btn" class="close-icon-btn">×</button>
            </div>
            <div class="opening-book-body">
              <!-- Current Opening Display -->
              <div id="current-opening-display" class="current-opening-section hidden">
                <h4>Aktuelle Eröffnung</h4>
                <div class="current-opening-info">
                  <div class="current-opening-name-row">
                    <span id="current-opening-name" class="current-opening-name"></span>
                    <span id="current-opening-eco" class="current-opening-eco"></span>
                  </div>
                  <span id="current-opening-category" class="current-opening-category"></span>
                  <div id="current-opening-stats" class="current-opening-stats"></div>
                  <div id="current-opening-moves" class="current-opening-moves"></div>
                  <p id="current-opening-description" class="current-opening-description"></p>
                </div>
              </div>

              <!-- Book Move Suggestion -->
              <div class="book-move-section">
                <h4>Buchzug-Vorschlag</h4>
                <div id="book-moves-list" class="book-moves-list"></div>
              </div>

              <!-- Opening Database Browser -->
              <div class="opening-browser-section">
                <div class="browser-controls">
                  <input type="text" id="opening-search" class="opening-search-input" placeholder="Eröffnung suchen (Name, ECO, Kategorie)...">
                  <select id="opening-category-filter" class="opening-category-filter">
                    <option value="all">Alle Kategorien</option>
                  </select>
                </div>
                <div id="opening-search-results" class="opening-search-results"></div>
                <div id="top-openings-list" class="top-openings-list"></div>
              </div>
            </div>
            </div>

            <!-- Statistics Overlay -->
            <div id="stats-overlay" class="stats-overlay hidden">
            <div class="stats-overlay-header">
              <h3>Statistiken</h3>
              <button id="close-stats-overlay" class="close-icon-btn">×</button>
            </div>
            <div class="stats-overlay-body">
              <div class="stat-row">
                <span class="stat-label">Gesamtzüge</span>
                <span id="stat-moves" class="stat-value">0</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Schlagen</span>
                <span id="stat-captures" class="stat-value">0</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Genauigkeit</span>
                <span id="stat-accuracy" class="stat-value">--%</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Elo-Schätzung</span>
                <span id="stat-elo" class="stat-value">—</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Beste Züge</span>
                <span id="stat-best-moves" class="stat-value">0</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Material</span>
                <span id="stat-material" class="stat-value">0</span>
              </div>
            </div>
          </div>

          <!-- Promotion Overlay -->
          <div id="promotion-overlay" class="promotion-overlay hidden">
            <div class="promotion-overlay-header">
              <h3>Bauernumwandlung</h3>
            </div>
            <div id="promotion-options" class="promotion-options">
            </div>
          </div>

          <!-- Shop Panel (Contextual) -->
          <div id="shop-panel" class="shop-panel hidden">
            <div class="shop-header">
              <h2>Truppen anheuern</h2>
              <div class="shop-points">
                <span id="points-display" data-testid="points-display">15</span> Pkt
              </div>
            </div>

            <!-- Tutor Recommendations Section -->
            <div id="tutor-recommendations-section" class="tutor-recommendations-section">
              <button id="toggle-tutor-recommendations" class="btn-secondary full-width" style="padding: 8px; font-size: 0.9rem; margin-bottom: 1rem">
                💡 KI-Vorlagen anzeigen
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- SIDE PANEL: Menu, Settings, Info -->
      <aside id="side-panel" class="side-panel hidden">
        <div class="side-panel-header">
          <h2>Menü</h2>
          <button id="close-side-panel-btn" class="close-icon-btn">×</button>
        </div>
        <div id="side-panel-content" class="side-panel-content">
          <!-- Content injected by JS -->
        </div>
      </aside>

      <!-- Modal Overlay for Side Panel -->
      <div id="side-panel-overlay" class="modal-overlay hidden"></div>
    </div>

    </div><!-- end main-content -->

    <!-- Service Worker Registration -->
    
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker
            .register('/service-worker.ts')
            .then((registration) => {
              console.log('[PWA] Service Worker registered:', registration.scope);
            })
            .catch((error) => {
              console.warn('[PWA] Service Worker registration failed:', error);
            });
        });
      }

      // Mobile menu toggle
      const toggle = document.querySelector('.nav-toggle');
      const navLinks = document.querySelector('.nav-links');
      if (toggle && navLinks) {
        toggle.addEventListener('click', () => {
          const isOpen = navLinks.classList.toggle('open');
          toggle.setAttribute('aria-expanded', isOpen);
        });
        navLinks.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            navLinks.classList.remove('open');
            toggle.setAttribute('aria-expanded', 'false');
          });
        });
      }

      // Touch feedback for board cells
      const board = document.getElementById('board');
      if (board) {
        board.addEventListener('touchstart', (e) => {
          const cell = e.target.closest('.cell');
          if (cell) cell.classList.add('touch-active');
        }, { passive: true });

        board.addEventListener('touchend', (e) => {
          const cell = e.target.closest('.cell');
          if (cell) cell.classList.remove('touch-active');
        }, { passive: true });

        // Prevent double-tap zoom on board
        board.addEventListener('dblclick', (e) => e.preventDefault());
      }
    </script>
  
"
`;

