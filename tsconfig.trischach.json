{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@trischach/*": ["js/trischach/*"]
    }
  },
  "include": [
    "js/trischach/**/*.ts",
    "tests/trischach/**/*.ts",
    "tests/trischach/**/*.js",
    "tests-e2e/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
