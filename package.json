{
  "name": "base3",
  "version": "1.0.0",
  "description": "Merged project: Schach9x9 (9x9 chess) + Trischach (3-player hexagonal chess)",
  "type": "module",
  "scripts": {
    "lint": "eslint . --ext .ts,.js,.mjs,.cjs",
    "lint:fix": "eslint . --ext .ts,.js,.mjs,.cjs --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "wasm:build": "wasm-pack build engine-wasm --target web",
    "build": "npm run wasm:build && vite build",
    "build:schach9x9": "vite build --config vite.config.schach9x9.ts",
    "build:trischach": "vite build --config vite.config.trischach.ts",
    "dev": "vite",
    "dev:schach9x9": "vite --config vite.config.schach9x9.ts",
    "dev:trischach": "vite --config vite.config.trischach.ts",
    "train:schach9x9": "node schach9x9/opening-book-trainer-real.cjs",
    "train:schach9x9:fast": "node schach9x9/opening-book-trainer-real.cjs --games 50",
    "tournament:trischach": "node trischach/tournament.js",
    "postinstall": "npm rebuild rolldown vite esbuild || true"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@types/three": "^0.182.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.5.0",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.6.0",
    "happy-dom": "^14.12.3",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.2.0",
    "jsdoc": "^4.0.5",
    "jsdom": "^29.1.1",
    "prettier": "^3.0.0",
    "serve": "^14.2.6",
    "terser": "^5.48.0",
    "ts-jest": "^29.4.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.17",
    "wasm-pack": "^0.15.0"
  },
  "dependencies": {
    "three": "^0.184.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
