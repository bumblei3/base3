{
  "name": "base3",
  "version": "1.1.1",
  "description": "Merged project: Schach9x9 (9x9 chess) + Trischach (3-player hexagonal chess)",
  "type": "module",
  "scripts": {
    "lint": "eslint . --ext .ts,.js,.mjs,.cjs",
    "lint:fix": "eslint . --ext .ts,.js,.mjs,.cjs --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "docs:api": "typedoc",
    "build": "npm run build:landing && npm run build:schach9x9 && npm run build:trischach",
    "build:landing": "vite build --config vite.landing.config.ts",
    "build:schach9x9": "vite build --config vite.config.schach9x9.ts && cp dist/schach9x9/index.schach9x9.html dist/schach9x9/index.html",
    "build:trischach": "vite build --config vite.config.trischach.ts && cp dist/trischach/index.trischach.html dist/trischach/index.html",
    "dev": "vite --config vite.landing.config.ts",
    "dev:schach9x9": "vite --config vite.config.schach9x9.ts",
    "dev:trischach": "vite --config vite.config.trischach.ts",
    "train:schach9x9": "node schach9x9/opening-book-trainer-real.cjs",
    "train:schach9x9:fast": "node schach9x9/opening-book-trainer-real.cjs --games 50",
    "tournament:trischach": "node trischach/tournament.js",
    "postinstall": "npm rebuild rolldown vite esbuild || true",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@chromatic-com/storybook": "^5.2.1",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-onboarding": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/html-vite": "^10.4.6",
    "@storybook/vue3-vite": "^10.4.6",
    "@types/node": "^26.1.0",
    "@types/three": "^0.185.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.6.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-storybook": "^10.4.6",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jsdoc": "^4.0.5",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0",
    "prettier": "^3.9.4",
    "serve": "^14.2.6",
    "storybook": "^10.4.6",
    "terser": "^5.48.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vite-bundle-visualizer": "^1.2.1",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "@sentry/browser": "^10.63.0",
    "three": "^0.185.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
