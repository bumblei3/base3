{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node", "vitest", "happy-dom"],
    "baseUrl": ".",
    "paths": {
      "@schach9x9/*": ["js/schach9x9/*"],
      "@trischach/*": ["js/trischach/*"],
      "@shared/*": ["js/shared/*"]
    }
  },
  "include": [
    "js/schach9x9/**/*.ts",
    "js/trischach/**/*.ts",
    "js/shared/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "tests-e2e",
    "e2e",
    "**/*.config.ts",
    "**/vitest.setup.ts",
    "**/playwright.config.ts",
    "**/test-utils.ts",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}